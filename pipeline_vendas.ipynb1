   },
   "outputs": [],
   "source": [
    "df_top = df_silver.groupBy(\"Produto\") \\\n",
    "    .agg(sum(\"Total_Calculado\").alias(\"Faturamento\")) \\\n",
    "    .orderBy(\"Faturamento\", ascending=False)\n",
    "\n",
    "display(df_top)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
