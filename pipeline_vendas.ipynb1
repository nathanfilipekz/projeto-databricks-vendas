   "source": [
    "from pyspark.sql.functions import sum\n",
    "\n",
    "df_gold = df_silver.groupBy(\"Produto\") \\\n",
    "    .agg(sum(\"Total_Calculado\").alias(\"Faturamento_Total\"))\n",
    "\n",
    "display(df_gold)"
   ]
