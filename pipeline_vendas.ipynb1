  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "4b3c3044-adb8-4e56-b198-b641f0384928",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "from pyspark.sql.functions import col, to_date\n",
    "\n",
    "df = spark.read.table(\"vendas_raw\")\n",
    "\n",
    "df_silver = df \\\n",
    "    .withColumn(\"Data\", to_date(col(\"Data\"))) \\\n",
    "    .withColumn(\"Total_Calculado\", col(\"Quantidade\") * col(\"Preco_Unitario\")) \\\n",
    "    .drop(\"Total\")\n",
    "\n",
    "display(df_silver)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
