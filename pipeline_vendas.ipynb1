   "source": [
    "df_total = df_silver.groupBy() \\\n",
    "    .agg(sum(\"Total_Calculado\").alias(\"Faturamento_Total\"))\n",
    "\n",
    "display(df_total)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
